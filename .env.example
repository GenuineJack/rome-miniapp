# ─── Database ────────────────────────────────────────────────────────────────
# Postgres connection string — required for all DB operations.
# On Vercel: set this to your Neon / Supabase / Railway connection string.
# The app auto-creates all tables and seeds 63 spots on first startup.
# No manual drizzle-kit push or seed API calls needed.
DATABASE_URL=postgresql://user:password@localhost:5432/boston

# ─── Neynar ──────────────────────────────────────────────────────────────────
NEYNAR_API_KEY=
NEXT_PUBLIC_NEYNAR_CLIENT_ID=

# ─── Admin ───────────────────────────────────────────────────────────────────
# Your Farcaster FID — gates the /admin page
ADMIN_FID=218957
# Secret for desktop/browser admin access — generate with: openssl rand -hex 32
ADMIN_SECRET=

# ─── App URLs ────────────────────────────────────────────────────────────────
# Canonical production URL — used for deep-link share URLs (?spotId=, ?builderId=)
NEXT_PUBLIC_APP_URL=https://boston-miniapp.vercel.app
# Set by Vercel automatically — do not set manually
NEXT_PUBLIC_VERCEL_PRODUCTION_URL=
NEXT_PUBLIC_LOCAL_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=

# ─── Optional ────────────────────────────────────────────────────────────────
WEBHOOK_URL=
COINGECKO_API_KEY=
# Protects /api/seed-spots and /api/migrate-spots endpoints — set to any random string
SEED_SECRET=
NEXT_PUBLIC_USER_FID=218957
